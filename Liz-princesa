<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<title>Para Liz Princesa 💛</title>

<style>
body{
  margin:0;
  font-family: Arial;
  background:black;
  color:white;
  overflow:hidden;
}

/* Fondo */
.night{
  position:fixed;
  width:100%;
  height:100%;
  background: radial-gradient(circle at bottom, #020111, #000);
}

/* Inicio */
.start{
  position:absolute;
  width:100%;
  height:100%;
  display:flex;
  justify-content:center;
  align-items:center;
}

.btn{
  background:#25D366;
  padding:15px 25px;
  border-radius:10px;
  font-size:18px;
  cursor:pointer;
  box-shadow:0 0 20px rgba(0,0,0,0.5);
}

/* Contenido */
.content{
  display:none;
  text-align:center;
  position:absolute;
  top:50%;
  left:50%;
  transform:translate(-50%, -50%);
  width:90%;
}

/* Foto */
img{
  width:260px;
  border-radius:20px;
  box-shadow:0 0 30px rgba(255,255,255,0.6);
  animation:fadeIn 3s;
}

/* Flores */
.flowers{
  position:absolute;
  bottom:0;
  width:100%;
  display:flex;
  justify-content:center;
  gap:40px;
}

.flower{
  width:15px;
  height:0;
  background:green;
  animation:grow 4s forwards;
}

.flower::before{
  content:"🌻";
  position:absolute;
  top:-40px;
  font-size:42px;
}

/* Texto */
.text{
  margin-top:20px;
  padding:20px;
  line-height:1.7;
  font-size:18px;
  animation:fadeIn 5s;
}

/* Corazones */
.heart{
  position:absolute;
  color:#ff4da6;
  animation:float 6s linear infinite;
}

@keyframes float{
  from{transform:translateY(100vh);opacity:1;}
  to{transform:translateY(-10vh);opacity:0;}
}

@keyframes grow{
  to{height:150px;}
}

@keyframes fadeIn{
  from{opacity:0;}
  to{opacity:1;}
}
</style>

</head>

<body>

<div class="night"></div>

<!-- MUSICA -->
<audio id="music">
  <source src="https://files.catbox.moe/8kq7c7.mp3" type="audio/mp3">
</audio>

<!-- INICIO -->
<div class="start" id="start">
  <div class="btn" onclick="startSurprise()">
    💌 Liz Princesa… toca aquí 💛
  </div>
</div>

<!-- CONTENIDO -->
<div class="content" id="content">

  <img src="https://i.postimg.cc/QtXTycc8/Whats-App-Image-2026-03-23-at-10-06-47.jpg">

  <div class="text">
    🌻 Feliz día de las flores amarillas mi amor 💛<br><br>

    No sé en qué momento te volviste  
    lo más importante de mi vida… ❤️<br><br>

    Pero hoy sé que no quiero un día sin ti,  
    ni una vida donde no estés tú 🥹<br><br>

    Gracias por tu amor, por tu paciencia,  
    por cada abrazo… y por no soltarme 💕<br><br>

    Liz Princesa, tú eres mi todo 💛🌻<br><br>

    Te amo más de lo que puedo explicar ❤️
  </div>

  <div class="flowers">
    <div class="flower"></div>
    <div class="flower"></div>
    <div class="flower"></div>
  </div>

</div>

<script>

/* INICIO */
function startSurprise(){
  document.getElementById("start").style.display="none";
  document.getElementById("content").style.display="block";
  document.getElementById("music").play();
}

/* CORAZONES */
setInterval(()=>{
  let h=document.createElement("div");
  h.className="heart";
  h.innerHTML="💖";
  h.style.left=Math.random()*100+"vw";
  h.style.fontSize=(Math.random()*20+10)+"px";
  document.body.appendChild(h);
  setTimeout(()=>h.remove(),6000);
},500);

</script>

</body>
body{
  overflow:auto;
}
</html>
