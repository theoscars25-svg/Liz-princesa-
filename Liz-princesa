<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<title>Para Liz Princesa 💛</title>

<style>
body{
  margin:0;
  background:black;
  overflow:hidden;
  font-family: Arial;
  color:white;
}

/* Fondo */
.night{
  position:fixed;
  width:100%;
  height:100%;
  background: radial-gradient(circle at bottom, #020111, #000);
}

/* Corazones */
.heart{
  position:absolute;
  color:#ff4da6;
  animation:float 6s linear infinite;
}
@keyframes float{
  from{transform:translateY(100vh);opacity:1;}
  to{transform:translateY(-10vh);opacity:0;}
}

/* CHAT */
.chat{
  position:absolute;
  top:20%;
  width:100%;
  padding:10px;
}

.bubble{
  background:#25D366;
  padding:10px;
  border-radius:10px;
  margin:8px;
  width:max-content;
  max-width:70%;
  animation:fadeIn 1s;
}

.bubble.you{
  margin-left:auto;
  background:#128C7E;
}

/* FOTO */
.photo{
  display:none;
  position:absolute;
  top:20%;
  width:100%;
  text-align:center;
  animation:fadeIn 3s;
}
.photo img{
  width:230px;
  border-radius:20px;
  box-shadow:0 0 30px white;
}

/* FLORES */
.flowers{
  position:absolute;
  bottom:0;
  width:100%;
  display:flex;
  justify-content:center;
  gap:40px;
}

.flower{
  width:15px;
  height:0;
  background:green;
  animation:grow 4s forwards;
}
.flower::before{
  content:"🌻";
  position:absolute;
  top:-40px;
  font-size:40px;
}

@keyframes grow{
  to{height:150px;}
}

/* MENSAJE FINAL */
.final{
  display:none;
  position:absolute;
  bottom:10%;
  text-align:center;
  width:100%;
  padding:20px;
  line-height:1.6;
  animation:fadeIn 4s;
}

@keyframes fadeIn{
  from{opacity:0;}
  to{opacity:1;}
}
</style>

</head>

<body>

<div class="night"></div>

<!-- MUSICA -->
<iframe width="0" height="0"
src="https://www.youtube.com/embed/mrXpa-6ZhBM?autoplay=1&loop=1&playlist=mrXpa-6ZhBM"
allow="autoplay">
</iframe>

<!-- CHAT -->
<div class="chat" id="chat"></div>

<!-- FOTO -->
<div class="photo" id="photo">
  <img src="https://i.postimg.cc/QtXTycc8/Whats-App-Image-2026-03-23-at-10-06-47.jpg">
</div>

<!-- FLORES -->
<div class="flowers" id="flowers" style="display:none;">
  <div class="flower"></div>
  <div class="flower"></div>
  <div class="flower"></div>
</div>

<!-- MENSAJE FINAL -->
<div class="final" id="final">
Liz Princesa… 💛<br><br>

No sé cómo explicarte todo lo que siento…<br><br>

Llegaste a mi vida y cambiaste todo,  
le diste luz a mis días y sentido a mi mundo ❤️<br><br>

Gracias por tu amor, por tu paciencia,  
por cada abrazo, cada beso… y cada momento 🥹<br><br>

Hoy te regalo estas flores amarillas 🌻  
como símbolo de todo lo que significas para mí 💛<br><br>

Te amo más de lo que las palabras pueden decir… ❤️
</div>

<script>

/* CORAZONES */
setInterval(()=>{
  let h=document.createElement("div");
  h.className="heart";
  h.innerHTML="💖";
  h.style.left=Math.random()*100+"vw";
  h.style.fontSize=(Math.random()*20+10)+"px";
  document.body.appendChild(h);
  setTimeout(()=>h.remove(),6000);
},500);

/* CHAT ANIMADO */
let mensajes=[
"Liz Princesa… 💛",
"Tengo algo que decirte…",
"No es cualquier mensaje…",
"Es algo que siento desde el corazón ❤️",
"Prométeme que lo vas a ver hasta el final… 🥺"
];

let chat=document.getElementById("chat");

function mostrarChat(i){
  if(i<mensajes.length){
    let div=document.createElement("div");
    div.className="bubble";
    div.innerText=mensajes[i];
    chat.appendChild(div);
    setTimeout(()=>mostrarChat(i+1),1500);
  }else{
    setTimeout(mostrarFoto,2000);
  }
}

function mostrarFoto(){
  chat.style.display="none";
  document.getElementById("photo").style.display="block";

  setTimeout(()=>{
    document.getElementById("flowers").style.display="flex";
  },2000);

  setTimeout(()=>{
    document.getElementById("final").style.display="block";
  },4000);
}

/* INICIO AUTOMATICO */
mostrarChat(0);

</script>

</body>
</html>
